<Window x:Class="VoiceType.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VoiceType Settings"
        Width="560" Height="720"
        MinWidth="480" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        ResizeMode="CanResize">

    <Window.Resources>
        <Storyboard x:Key="EntranceStoryboard">
                <DoubleAnimation Storyboard.TargetName="ContentRoot"
                                 Storyboard.TargetProperty="Opacity"
                                 From="0" To="1" Duration="0:0:0.38">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation Storyboard.TargetName="SlideTransform"
                                 Storyboard.TargetProperty="Y"
                                 From="14" To="0" Duration="0:0:0.38">
                    <DoubleAnimation.EasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                    </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
            </Storyboard>
    </Window.Resources>

    <Border x:Name="WindowChrome" CornerRadius="14" Padding="1"
            Background="#CC0A0A0A" BorderBrush="#26FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.45" Color="Black"/>
        </Border.Effect>

        <Grid x:Name="ContentRoot" Opacity="0">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="SlideTransform" Y="14"/>
            </Grid.RenderTransform>

            <Grid Margin="28,24,28,22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="44" Height="44" CornerRadius="22"
                                Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#D97757" Offset="0"/>
                                    <GradientStop Color="#C46548" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border BorderBrush="#55FFFFFF" BorderThickness="1" CornerRadius="22">
                                <Viewbox Width="20" Height="20">
                                    <Path Data="M12,6.5 C13.4,6.5 14.5,7.6 14.5,9 V11.5 C14.5,13.4 13.4,14.5 12,14.5 C10.6,14.5 9.5,13.4 9.5,11.5 V9 C9.5,7.6 10.6,6.5 12,6.5 Z M8.5,12.5 C8.5,14.8 10.1,16.5 12,16.5 C13.9,16.5 15.5,14.8 15.5,12.5"
                                          Stroke="White" StrokeThickness="1.6"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Fill="Transparent" Stretch="Uniform"/>
                                </Viewbox>
                            </Border>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="VoiceType" Style="{StaticResource HeroTitle}" Margin="0"/>
                            <TextBlock Text="Push-to-talk dictation" Style="{StaticResource HeroSubtitle}"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Height="1" Background="#18FFFFFF" Margin="0,4,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <TextBlock Text="HOTKEY" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource GlassCard}" x:Name="CardHotkey">
                            <StackPanel>
                                <WrapPanel Margin="0,0,0,4">
                                    <CheckBox Content="Ctrl"  IsChecked="{Binding Ctrl}"  Style="{StaticResource GlassCheckBox}"/>
                                    <CheckBox Content="Shift" IsChecked="{Binding Shift}" Style="{StaticResource GlassCheckBox}"/>
                                    <CheckBox Content="Alt"   IsChecked="{Binding Alt}"   Style="{StaticResource GlassCheckBox}"/>
                                    <CheckBox Content="Win"   IsChecked="{Binding Win}"   Style="{StaticResource GlassCheckBox}"/>
                                </WrapPanel>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Key" VerticalAlignment="Center" Margin="0,0,14,0"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                                    <ComboBox Grid.Column="1"
                                              Style="{StaticResource GlassComboBox}"
                                              ItemsSource="{Binding KeyNames}"
                                              SelectedItem="{Binding SelectedKey}"/>
                                </Grid>

                                <Border Margin="0,16,0,0" CornerRadius="10" Padding="12,10"
                                        Background="#14D97757" BorderBrush="#33D97757" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Active" FontSize="12" Margin="0,0,10,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding HotkeyPreview}" FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Style="{StaticResource HintText}" Margin="0,12,0,0"
                                           Text="Hold while speaking, release to transcribe. Text appears a moment later — not live as you speak. Side mouse buttons work without modifiers."/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="MICROPHONE" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource GlassCard}" x:Name="CardMic">
                            <ComboBox Style="{StaticResource GlassComboBox}"
                                      ItemsSource="{Binding Microphones}"
                                      SelectedItem="{Binding SelectedMic}"
                                      DisplayMemberPath="Name"/>
                        </Border>

                        <TextBlock Text="SPEECH MODEL" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource GlassCard}" x:Name="CardEngine">
                            <StackPanel>
                                <TextBlock Style="{StaticResource HintText}" Margin="0,0,0,12"
                                           Text="Free local Whisper — runs on your PC, no API key, no usage fees. First use downloads the model once."/>
                                <TextBlock Text="Model" FontSize="12" Margin="0,0,0,8"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <ComboBox Style="{StaticResource GlassComboBox}"
                                          ItemsSource="{Binding WhisperModelNames}"
                                          SelectedItem="{Binding SelectedWhisperModel}"/>
                                <TextBlock Style="{StaticResource HintText}" Margin="0,12,0,0"
                                           Text="Base English is the best balance. Tiny English is fastest if replies feel slow. You can record again while the previous clip transcribes."/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="GENERAL" Style="{StaticResource SectionLabel}"/>
                        <Border Style="{StaticResource GlassCard}" x:Name="CardGeneral" Margin="0">
                            <StackPanel>
                                <CheckBox Content="Play audio cues" IsChecked="{Binding PlayBeep}"
                                          Style="{StaticResource GlassCheckBox}" Margin="0,0,0,4"/>
                                <CheckBox Content="Type finished text (instead of Ctrl+V paste)"
                                          IsChecked="{Binding TypeInsteadOfPaste}"
                                          Style="{StaticResource GlassCheckBox}" Margin="0,0,0,4"/>
                                <TextBlock Style="{StaticResource HintText}" Margin="0,0,0,12"
                                           Text="Types the completed transcript character-by-character after you release the hotkey. Not live dictation while you speak."/>
                                <CheckBox Content="Start with Windows" IsChecked="{Binding StartWithWindows}"
                                          Style="{StaticResource GlassCheckBox}" Margin="0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <Grid Grid.Row="2" Margin="0,18,0,0">
                    <TextBlock Text="Logs: %APPDATA%\VoiceType\logs"
                               Style="{StaticResource HintText}" VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Style="{StaticResource GlassButton}"
                                Margin="0,0,10,0" Click="Cancel_Click"/>
                        <Button Content="Save changes" Style="{StaticResource AccentButton}"
                                Click="Save_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
